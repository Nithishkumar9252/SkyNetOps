

# ===== Azure AI Agent (optional) =====
PROJECT_ENDPOINT="https://skynetops-ai-foundry.services.ai.azure.com/xxxxxxxxxxx"
MODEL_DEPLOYMENT_NAME="gpt5-skynetops"

# If you want to use API key auth for AgentsClient (optional): set true and provide key
USE_API_KEY=false
AZURE_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

SUBSCRIPTION_ID=xxxxxxxxxxxxxxx-xxxxx-xxxx
RESOURCE_GROUP=SkyNetOpsRG
VM_NAME=vm-01
VM_SSH_HOST=xxx.xxx.xx.xxx
VM_SSH_PORT=22
VM_SSH_USERNAME=azureuser
VM_SSH_PASSWORD=
VM_SSH_KEY_PATH=xxxxxxxxxxxxxxxxxxx
VM_SSH_USE_SUDO=true

SN_INSTANCE_URL=xxxxxxxxxxxxxxxxxxx
SN_USERNAME=admin
SN_PASSWORD=xxxxxxxxxx
SN_ATTACH_ON_UPDATE=1
SN_VERIFY=false



# ===== Email (Gmail SMTP example) =====
EMAIL_ALERT_TO="xxxxxxxxxxxxxxxx@xxx.com"
EMAIL_ALERT_FROM="xxxxxxxxxxx@gmail.com"
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="xxxxxxxxxxxxxxxxx@gmail.com"
SMTP_PASSWORD=xxxxxxxxxxxxxxx

CPU_THRESHOLD=80
MEM_FREE_PCT_THRESHOLD=20
MEMORY_THRESHOLD=85
SEVERITY_MARGIN_P1=20
SEVERITY_MARGIN_P2=10
SEVERITY_MARGIN_P3=0

SN_IMPACT_P1=1
SN_URGENCY_P1=1
SN_IMPACT_P2=1
SN_URGENCY_P2=2
SN_IMPACT_P3=2
SN_URGENCY_P3=2


STORAGE_ACCOUNT_NAME=skynetopsstorage

LOG_ANALYTICS_WORKSPACE_ID=xxxxxxxxxxxxxxxx

# Tuning thresholds
AVAILABILITY_MIN_PCT=99.0
E2E_LATENCY_MS_WARN=250
SERVER_LATENCY_MS_WARN=80
THROTTLING_PER_MIN_WARN=5
AUTH_FAIL_PER_MIN_WARN=5
CAPACITY_DAILY_GROWTH_B=214748364800  # 200 GB/day




